{
  "expo": {
    "name": "avenas",
    "slug": "avenas",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "avenas",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Avenas uses your photo library to set your profile photo and to add an image or video to your custom exercises.",
        "NSCameraUsageDescription": "Avenas uses your camera to scan a connect code and to take a photo for your custom exercise.",
        "NSSupportsLiveActivities": true,
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.avenas.workout"
        ]
      },
      "bundleIdentifier": "com.avenas.app",
      "appleTeamId": "8X55YH783A",
      "buildNumber": "30",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-notifications",
      "@bacons/apple-targets",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "bundleIdentifier": "com.avenas.app.widget",
                  "targetName": "AvenasWorkoutWidget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.avenas.workout"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "339284cd-e4f5-4635-91db-b75806f732c9"
      }
    },
    "owner": "mikemikey"
  }
}
